&nl_colm_forcing

   ! ----- forcing -----
   DEF_dir_forcing  = '/stu01/caoxq18/data/Forcing/'

   DEF_forcing%dataset           = 'POINT' 
   DEF_forcing%solarin_all_band  = .true.  
   DEF_forcing%HEIGHT_V          = 4.    
   DEF_forcing%HEIGHT_T          = 4.
   DEF_forcing%HEIGHT_Q          = 4.
   
   DEF_forcing%NVAR              = 8        ! variable number of forcing data
   DEF_forcing%startyr           = 2014     ! start year of forcing data  
   DEF_forcing%startmo           = 1        ! start month of forcing data
   DEF_forcing%endyr             = 2016     ! end year of forcing data
   DEF_forcing%endmo             = 12       ! end month of forcing data
   DEF_forcing%dtime             = 3600 3600 3600 3600 3600 3600 3600 3600
   
   DEF_forcing%fprefix(1) = 'Ngoring-20140101-20161231.nc'
   DEF_forcing%fprefix(2) = 'Ngoring-20140101-20161231.nc'
   DEF_forcing%fprefix(3) = 'Ngoring-20140101-20161231.nc'
   DEF_forcing%fprefix(4) = 'Ngoring-20140101-20161231.nc'
   DEF_forcing%fprefix(5) = 'Ngoring-20140101-20161231.nc'
   DEF_forcing%fprefix(6) = 'Ngoring-20140101-20161231.nc'
   DEF_forcing%fprefix(7) = 'Ngoring-20140101-20161231.nc'
   DEF_forcing%fprefix(8) = 'Ngoring-20140101-20161231.nc'
   
   DEF_forcing%vname    = 'Tair' 'Qair' 'Psurf' 'Precip' 'Wind_u' 'Wind_v' 'SWdown' 'LWdown' 
   DEF_forcing%tintalgo = 'linear' 'linear' 'linear' 'nearest' 'linear' 'linear' 'coszen' 'linear'

/
